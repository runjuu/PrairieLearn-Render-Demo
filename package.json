{
  "name": "prairielearn-render-demo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "render:server": "pnpm run render:server:start",
    "render:server:start": "pnpm --dir PrairieLearn --filter @prairielearn/prairielearn exec tsx --tsconfig src/tsconfig.json src/preview-server.ts --course-dir \"$PWD/demo-course\" --host 127.0.0.1 --port 4310 --workers-execution-mode native",
    "start": "next start",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "beta",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
