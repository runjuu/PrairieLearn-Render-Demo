{
  "name": "prairielearn-render-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "render:server": "npm run render:server:build && npm run render:server:start",
    "render:server:build": "npm --prefix PrairieLearn/apps/prairielearn run build",
    "render:server:start": "npm --prefix PrairieLearn/apps/prairielearn run preview:server -- --course-dir \"$PWD/demo-course\"",
    "start": "next start",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "beta",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "dependencies": {
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
