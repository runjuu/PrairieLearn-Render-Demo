{
  "name": "prairielearn-render-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:css && npm run typecheck",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css",
    "dev": "tsx watch src/server.ts",
    "setup:prairielearn": "node scripts/setup-prairielearn.mjs",
    "start": "tsx src/server.ts",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^24.10.1",
    "@typescript/native-preview": "beta",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=24"
  }
}
